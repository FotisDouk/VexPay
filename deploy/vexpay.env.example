# Copy to vexpay.env and edit. Never commit the filled-in version.

# development | sandbox | production
VEXPAY_ENV=production

# The externally reachable base URL. Must be HTTPS in production.
VEXPAY_PUBLIC_URL=https://pay.example.com

# HTTP listen address inside the container.
VEXPAY_ADDR=:8080

# sqlite:<path> or postgres://user:pass@host:5432/dbname
VEXPAY_DATABASE_URL=sqlite:/data/vexpay.db

# Invoice / locked-rate validity window.
VEXPAY_INVOICE_EXPIRY=15m

# Signs admin dashboard sessions. Generate a long random value, e.g.:
#   openssl rand -hex 32
VEXPAY_ADMIN_SESSION_SECRET=
